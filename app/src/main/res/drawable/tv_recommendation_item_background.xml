<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
	<item android:state_focused="true">
		<shape>
			<solid android:color="#FF383838" />
			<stroke android:width="4dp" android:color="#FFFFFFFF" />
			<corners android:radius="4dp" />
		</shape>
	</item>
	<item android:state_selected="true">
		<shape>
			<solid android:color="#FF555555" />
			<stroke android:width="3dp" android:color="#FFDDDDDD" />
			<corners android:radius="4dp" />
		</shape>
	</item>
	<item>
		<shape>
			<solid android:color="#CC202020" />
			<stroke android:width="1dp" android:color="#66777777" />
			<corners android:radius="4dp" />
		</shape>
	</item>
</selector>
