<?xml version="1.0" encoding="utf-8"?>
<resources>
	<color name="colorPrimary">#121212</color>
	<color name="colorPrimaryDark">#000000</color>
	<color name="colorAccent">#D9D9D9</color>
	<color name="brightText">#FFF</color>
	<color name="darkerText">#F5F5F5</color>

	<color name="skytube_theme_colour">#ff6600</color>

	<!--
		Material Dialog Colors
	-->
	<color name="dialog_title">#000</color>
	<color name="dialog_background">@color/brightText</color>
	<color name="dialog_content_text">#000</color>
	<color name="dialog_positive_text">#1A1A1A</color>
	<color name="dialog_negative_text">#1A1A1A</color>
	<color name="dialog_neutral_text">#1A1A1A</color>
	<color name="dialog_row_0">#F0F0F0</color>
	<color name="dialog_row_1">@color/dialog_background</color>

	<!--
		Sponsorblock, contains transparency
	-->
	<color name="sponsorblock_category_sponsor">#B300d400</color>
	<color name="sponsorblock_category_selfpromo">#B3ffff00</color>
	<color name="sponsorblock_category_interaction">#B3cc00ff</color>
	<color name="sponsorblock_category_music_offtopic">#B3ff9900</color>
	<color name="sponsorblock_category_intro">#B300ffff</color>
	<color name="sponsorblock_category_outro">#B30202ed</color>
	<color name="sponsorblock_category_preview">#B3008fd6</color>
	<color name="sponsorblock_category_filler">#B37300FF</color>

	<!--
		Subs Drawer Colours
	-->
	<color name="subs_drawer_background">#CC0C0C0C</color>
	<drawable name="sub_channel_pressed">@color/colorAccent</drawable>
	<drawable name="sub_channel">@android:color/transparent</drawable>
	<color name="subs_text">@color/brightText</color>


	<!--
		Video (Grid) Cells
	-->
	<color name="video_cell_background">#141414</color>
	<color name="video_cell_text_main">#F5F5F5</color>
	<color name="video_cell_text_details">#A0A0A0</color>
	<color name="video_cell_highlighted_background">#202020</color>

	<color name="grid_view_background">#0B0B0B</color>
	<color name="popup_menu">#FF1A1A1A</color>  <!-- Identical to @color/background_material_dark -->


	<!--
		Video Player Tutorial
	-->
	<color name="tutorial_background">@color/colorPrimary</color>
	<color name="tutorial_swipe_area">#2A2A2A</color>


	<!--
		Video Player Colours
	-->
	<!-- Actionbar background colour ~~ which is the same as com.android.internal.R.layout.media_controller
				(used to be #BB000000) -->
	<color name="video_player_hud">#CC000000</color>
	<color name="video_player_drawer_background">@color/video_player_hud</color>
	<color name="video_player_drawer_text">#b3b3b3</color>

	<color name="video_desc_like_bar">@color/colorAccent</color>

	<!-- Comments -->
	<color name="comment_background">@color/video_player_hud</color>
	<color name="comment_text">#b3b3b3</color>

	<!-- Player v2 -->
	<color name="video_player_v2_hud">#7A000000</color>
	<color name="video_player_v2_seek_bar">#E6E6E6</color>


	<!--
		Channel Browser
	-->
	<color name="channel_subs">@color/video_cell_text_main</color>
	<color name="channel_about">@color/video_cell_text_main</color>
	<color name="channel_subscribers_bkg">#66000000</color>


	<!--
		Subscriptions Feed
	-->
	<color name="feed_message_text">@color/brightText</color>

</resources>
